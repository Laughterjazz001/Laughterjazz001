{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpecLock Spec v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["version","service","owners","objectives","nonGoals","constraints","changePolicy"],
  "properties": {
    "version": { "type": "string", "const": "0" },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name","summary"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name","contact"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "contact": { "type": "string", "minLength": 1 }
        }
      }
    },
    "objectives": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "nonGoals": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "changePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiresSpecUpdateFor"],
      "properties": {
        "requiresSpecUpdateFor": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}